{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/tmp-iplan.schema.json",
  "title": "Temporary IPLAN",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "tmp_kind": { "const": "investigation" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "scope": {
            "required": ["investigation_questions"],
            "properties": {
              "mutation_policy": { "const": "read_only" },
              "investigation_questions": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "tmp_kind": { "enum": ["correction", "hotfix"] }
            }
          }
        }
      },
      "then": {
        "properties": {
          "scope": {
            "required": ["correction_scope"],
            "properties": {
              "mutation_policy": { "enum": ["bounded_write", "approval_required"] },
              "correction_scope": { "minItems": 1 }
            }
          }
        }
      }
    }
  ],
  "required": [
    "metadata",
    "intent",
    "scope",
    "plan",
    "verification",
    "evidence_requirements",
    "source_iplan_handoff",
    "return_handoff",
    "handoff",
    "closure"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "document_type",
        "artifact_type",
        "tmp_iplan_id",
        "tmp_kind",
        "title",
        "status",
        "created_at",
        "expires_at",
        "owner",
        "promotion_policy"
      ],
      "properties": {
        "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(-draft)?$" },
        "document_type": { "const": "temporary-iplan" },
        "artifact_type": { "const": "TMP-IPLAN" },
        "tmp_iplan_id": { "type": "string", "pattern": "^TMP-IPLAN-[0-9]{4}-[0-9]{2}-[0-9]{2}-.+$" },
        "tmp_kind": { "enum": ["correction", "investigation", "hotfix", "spike"] },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["Draft", "Review", "Approved", "Active", "Completed", "Abandoned", "Promoted"] },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "owner": { "type": "string", "minLength": 1 },
        "promotion_policy": { "enum": ["never", "promote_if_scope_expands", "promote_before_execution"] }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "reason", "expected_outcome", "non_goals"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expected_outcome": { "type": "string", "minLength": 1 },
        "non_goals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in", "out", "risk_level", "mutation_policy", "expiration_rule"],
      "properties": {
        "in": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "out": { "type": "array", "items": { "type": "string" } },
        "risk_level": { "enum": ["low", "medium", "high"] },
        "mutation_policy": { "enum": ["read_only", "bounded_write", "approval_required"] },
        "correction_scope": { "type": "array", "items": { "type": "string" } },
        "investigation_questions": { "type": "array", "items": { "type": "string" } },
        "expiration_rule": { "type": "string", "minLength": 1 }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependencies", "steps"],
      "properties": {
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step_id",
              "title",
              "intent",
              "target_files",
              "commands",
              "executor_context",
              "executor_work",
              "evidence_required",
              "failure_handling",
              "status"
            ],
            "properties": {
              "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
              "title": { "type": "string", "minLength": 1 },
              "intent": { "type": "string", "minLength": 1 },
              "target_files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "action"],
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "action": { "enum": ["create", "modify", "delete", "read", "verify"] }
                  }
                }
              },
              "commands": {
                "type": "object",
                "additionalProperties": false,
                "required": ["setup", "execute", "verify"],
                "properties": {
                  "setup": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["items", "not_applicable_reason"],
                    "properties": {
                      "items": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                      "not_applicable_reason": { "type": ["string", "null"] }
                    }
                  },
                  "execute": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["items", "not_applicable_reason"],
                    "properties": {
                      "items": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 },
                        "minItems": 1
                      },
                      "not_applicable_reason": { "type": ["string", "null"] }
                    }
                  },
                  "verify": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["items", "not_applicable_reason"],
                    "properties": {
                      "items": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 },
                        "minItems": 1
                      },
                      "not_applicable_reason": { "type": ["string", "null"] }
                    }
                  }
                }
              },
              "executor_context": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "repository",
                  "workspace",
                  "knowledge_refs",
                  "mcp_tools",
                  "secrets_policy",
                  "forbidden_paths"
                ],
                "properties": {
                  "repository": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["url", "default_branch", "base_ref"],
                    "properties": {
                      "url": { "type": "string", "minLength": 1 },
                      "default_branch": { "type": "string", "minLength": 1 },
                      "base_ref": { "type": "string", "minLength": 1 }
                    }
                  },
                  "workspace": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["working_directory", "write_scope", "read_only_paths"],
                    "properties": {
                      "working_directory": { "type": "string", "minLength": 1 },
                      "write_scope": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                      "read_only_paths": { "type": "array", "items": { "type": "string" } }
                    }
                  },
                  "knowledge_refs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["ref_type", "ref", "required"],
                      "properties": {
                        "ref_type": { "enum": ["spec", "decision", "knowledge_base", "code_summary", "run_log"] },
                        "ref": { "type": "string", "minLength": 1 },
                        "required": { "type": "boolean" }
                      }
                    }
                  },
                  "mcp_tools": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["name", "purpose", "required"],
                      "properties": {
                        "name": { "type": "string", "minLength": 1 },
                        "purpose": { "type": "string", "minLength": 1 },
                        "required": { "type": "boolean" }
                      }
                    }
                  },
                  "secrets_policy": { "enum": ["no_secrets", "scoped_runtime_only", "managed_by_iplanic"] },
                  "forbidden_paths": { "type": "array", "items": { "type": "string" } }
                }
              },
              "executor_work": {
                "type": "object",
                "additionalProperties": false,
                "required": ["work_order_id", "dispatchable", "todos", "reporting"],
                "properties": {
                  "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
                  "dispatchable": { "type": "boolean", "description": "true: the work order is dispatched to a remote executor as a runtime task. false: it is part of the plan but not dispatched (a human gate, manual, or platform-internal step) — tracked, but dispatch skips remote assignment." },
                  "todos": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "todo_id",
                        "description",
                        "type",
                        "priority",
                        "allowed_actions",
                        "acceptance_criteria",
                        "evidence_required",
                        "status"
                      ],
                      "properties": {
                        "todo_id": { "type": "string", "pattern": "^TODO-[0-9]{3,}$" },
                        "description": { "type": "string", "minLength": 1 },
                        "type": { "enum": ["inspect", "edit", "create", "delete", "test", "review", "document", "verify"] },
                        "priority": { "enum": ["P0", "P1", "P2", "P3"] },
                        "allowed_actions": {
                          "type": "array",
                          "items": {
                            "enum": [
                              "read",
                              "create",
                              "modify",
                              "delete",
                              "run_command",
                              "call_tool",
                              "submit_artifact",
                              "request_clarification"
                            ]
                          },
                          "minItems": 1,
                          "uniqueItems": true
                        },
                        "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                        "evidence_required": {
                          "type": "array",
                          "minItems": 1,
                          "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["event_type", "artifact_type", "description"],
                            "properties": {
                              "event_type": { "type": "string", "minLength": 1 },
                              "artifact_type": { "type": "string", "minLength": 1 },
                              "description": { "type": "string", "minLength": 1 }
                            }
                          }
                        },
                        "status": {
                          "enum": ["Not Started", "Queued", "Running", "Blocked", "Completed", "Failed", "Cancelled"]
                        }
                      }
                    }
                  },
                  "reporting": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "progress_events",
                      "completion_event",
                      "artifact_manifest_required",
                      "final_summary_required"
                    ],
                    "properties": {
                      "progress_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                      "completion_event": { "const": "task.completed" },
                      "artifact_manifest_required": { "type": "boolean" },
                      "final_summary_required": { "type": "boolean" }
                    }
                  }
                }
              },
              "evidence_required": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "failure_handling": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "on_blocker",
                  "on_ambiguity",
                  "on_test_failure",
                  "on_policy_denial",
                  "on_partial_completion"
                ],
                "properties": {
                  "on_blocker": { "type": "string", "minLength": 1 },
                  "on_ambiguity": { "type": "string", "minLength": 1 },
                  "on_test_failure": { "type": "string", "minLength": 1 },
                  "on_policy_denial": { "type": "string", "minLength": 1 },
                  "on_partial_completion": { "type": "string", "minLength": 1 }
                }
              },
              "status": { "enum": ["Not Started", "Queued", "Running", "Blocked", "Completed", "Failed", "Cancelled"] }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_commands", "completion_criteria"],
      "properties": {
        "required_commands": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "completion_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_events", "required_artifacts", "approvals"],
      "properties": {
        "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_artifacts": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "approvals": { "type": "array", "items": { "type": "object" } }
      }
    },
    "source_iplan_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "source_iplan_ref",
        "trigger",
        "allowed_scope",
        "pause_standard_iplan",
        "return_contract"
      ],
      "properties": {
        "handoff_id": { "type": "string", "pattern": "^TMP-HANDOFF-[0-9]{3,}$" },
        "source_iplan_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": ["iplan_id", "plan_version_id", "step_id", "work_order_id"],
          "properties": {
            "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
            "plan_version_id": { "type": "string", "minLength": 1 },
            "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
            "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
            "task_id": { "type": ["string", "null"] },
            "run_id": { "type": ["string", "null"] }
          }
        },
        "trigger": {
          "enum": [
            "blocked_step",
            "defect",
            "investigation",
            "policy_exception",
            "urgent_correction"
          ]
        },
        "allowed_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["file_patterns", "actions", "policy_refs"],
          "properties": {
            "file_patterns": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "actions": {
              "type": "array",
              "items": { "enum": ["read", "create", "modify", "delete", "run_command", "call_tool", "submit_artifact"] },
              "minItems": 1,
              "uniqueItems": true
            },
            "policy_refs": { "type": "array", "items": { "type": "string" } }
          }
        },
        "pause_standard_iplan": { "type": "boolean" },
        "return_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected_return_to_step", "required_evidence", "required_decision", "max_duration"],
          "properties": {
            "expected_return_to_step": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
            "required_evidence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "required_decision": { "enum": ["resume", "keep_blocked", "promote", "abandon"] },
            "max_duration": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "return_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_id",
        "target_iplan_ref",
        "return_gate",
        "allowed_resume_actions",
        "promotion_rules"
      ],
      "properties": {
        "handoff_id": { "type": "string", "pattern": "^TMP-HANDOFF-[0-9]{3,}$" },
        "target_iplan_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": ["iplan_id", "plan_version_id", "step_id", "work_order_id"],
          "properties": {
            "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
            "plan_version_id": { "type": "string", "minLength": 1 },
            "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
            "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" }
          }
        },
        "return_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required_events", "required_artifacts", "required_review", "decision_owner"],
          "properties": {
            "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "required_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "required_review": { "type": "boolean" },
            "decision_owner": { "type": "string", "minLength": 1 }
          }
        },
        "allowed_resume_actions": {
          "type": "array",
          "items": {
            "enum": [
              "resume_standard_iplan",
              "keep_blocked",
              "promote_to_permanent_iplan",
              "abandon_tmp"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "promotion_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["promotion_policy", "promotion_required_when"],
          "properties": {
            "promotion_policy": { "enum": ["never", "promote_if_scope_expands", "promote_before_execution"] },
            "promotion_required_when": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "return_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "evidence_refs", "resume_action", "promotion_decision", "completed_at"],
      "properties": {
        "outcome": { "enum": [null, "completed", "blocked", "failed", "abandoned", "promoted"] },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "resume_action": {
          "enum": [
            null,
            "resume_standard_iplan",
            "keep_blocked",
            "promote_to_permanent_iplan",
            "abandon_tmp"
          ]
        },
        "promotion_decision": { "enum": [null, "not_required", "required", "promoted", "rejected"] },
        "completed_at": { "type": ["string", "null"] }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_state", "resume_from_step", "blockers", "sessions"],
      "properties": {
        "current_state": { "type": "string", "minLength": 1 },
        "resume_from_step": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "sessions": { "type": "array", "items": { "type": "object" } }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "promoted_to_permanent_iplan",
        "permanent_iplan_ref",
        "cleanup_required",
        "evidence_bundle_ref"
      ],
      "properties": {
        "result": { "type": ["string", "null"] },
        "promoted_to_permanent_iplan": { "type": "boolean" },
        "permanent_iplan_ref": { "type": ["string", "null"] },
        "cleanup_required": { "type": "boolean" },
        "evidence_bundle_ref": { "type": ["string", "null"] }
      }
    }
  }
}
