{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/iplan-execution-record.schema.json",
  "title": "IPLAN Execution Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "plan_ref",
    "tasks",
    "executor_assignments",
    "events",
    "artifacts",
    "policy_decisions",
    "state_transitions",
    "verification"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "document_type",
        "run_id",
        "org_id",
        "project_id",
        "created_at",
        "updated_at",
        "status"
      ],
      "properties": {
        "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(-draft)?$" },
        "document_type": { "const": "iplan-execution-record" },
        "run_id": { "type": "string", "minLength": 1 },
        "org_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "status": {
          "enum": ["Queued", "Running", "Blocked", "Completed", "Failed", "Cancelled", "Abandoned"]
        }
      }
    },
    "plan_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iplan_id", "plan_version_id", "chain_id", "imported_artifact_ref"],
      "properties": {
        "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
        "plan_version_id": { "type": "string", "minLength": 1 },
        "chain_id": { "type": ["string", "null"] },
        "imported_artifact_ref": { "type": "string", "minLength": 1 }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "step_id", "work_order_id", "status", "executor_id", "lease_id", "attempts"],
        "properties": {
          "task_id": { "type": "string", "minLength": 1 },
          "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
          "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
          "status": { "enum": ["Queued", "Assigned", "Running", "Blocked", "Completed", "Failed", "Cancelled"] },
          "executor_id": { "type": ["string", "null"], "pattern": "^exec:[a-z2-7]{16,}$" },
          "lease_id": { "type": ["string", "null"] },
          "max_attempts": { "type": "integer", "minimum": 1, "description": "Retry cap for this task (default 1 when absent). Carried from the plan's verification.max_attempts at materialize; bounds attempts[] length." },
          "attempts": {
            "type": "array",
            "description": "Recorded task attempts, bounded by max_attempts (default 1). result: pending = in-flight (no budget consumed); failed = retryable to the cap then terminal Failed; blocked = resolution-driven, not auto-retried; succeeded/cancelled = terminal. See IPLAN-STANDARD.md (Retry & Attempt Cap).",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["attempt", "started_at", "completed_at", "result"],
              "properties": {
                "attempt": { "type": "integer", "minimum": 1 },
                "started_at": { "type": ["string", "null"], "format": "date-time" },
                "completed_at": { "type": ["string", "null"], "format": "date-time" },
                "result": { "enum": ["pending", "succeeded", "failed", "cancelled", "blocked"] }
              }
            }
          }
        }
      }
    },
    "executor_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assignment_id", "task_id", "executor_id", "capability_match", "granted_scopes", "assigned_at"],
        "properties": {
          "assignment_id": { "type": "string", "minLength": 1 },
          "task_id": { "type": "string", "minLength": 1 },
          "executor_id": { "type": "string", "pattern": "^exec:[a-z2-7]{16,}$" },
          "capability_match": { "type": "array", "items": { "type": "string" } },
          "granted_scopes": { "type": "array", "items": { "type": "string" } },
          "assigned_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted", "rejected"],
      "properties": {
        "accepted": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["event_id", "event_type", "task_id", "executor_id", "status", "occurred_at"],
            "properties": {
              "event_id": { "type": "string", "minLength": 1 },
              "event_type": { "type": "string", "minLength": 1 },
              "task_id": { "type": "string", "minLength": 1 },
              "executor_id": { "type": "string", "pattern": "^exec:[a-z2-7]{16,}$" },
              "status": { "enum": ["accepted", "running", "blocked", "succeeded", "failed", "cancelled"] },
              "occurred_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "rejected": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["event_id", "reason", "rejected_at"],
            "properties": {
              "event_id": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 },
              "rejected_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted", "rejected"],
      "properties": {
        "accepted": { "type": "array", "items": { "type": "object" } },
        "rejected": { "type": "array", "items": { "type": "object" } }
      }
    },
    "policy_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_id", "subject", "action", "resource", "result", "decided_at"],
        "properties": {
          "decision_id": { "type": "string", "minLength": 1 },
          "subject": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 },
          "resource": { "type": "string", "minLength": 1 },
          "result": { "enum": ["allow", "deny", "warning"] },
          "decided_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "state_transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "reason", "at"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands_run", "evidence_status", "completion_gate", "required_evidence"],
      "properties": {
        "commands_run": { "type": "array", "items": { "type": "object" } },
        "evidence_status": { "enum": ["pending", "passed", "failed", "partial"] },
        "completion_gate": { "enum": ["pending", "passed", "failed", "blocked"] },
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["evidence_id", "status", "required_for_completion"],
            "properties": {
              "evidence_id": { "type": "string", "minLength": 1 },
              "status": { "enum": ["missing", "accepted", "rejected", "waived"] },
              "required_for_completion": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
