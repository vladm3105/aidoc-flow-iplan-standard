{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/iplan-lifecycle-event.schema.json",
  "title": "IPLAN Lifecycle Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "artifact_type",
    "iplan_id",
    "plan_version_id",
    "event_type",
    "from_status",
    "to_status",
    "actor",
    "occurred_at",
    "reason",
    "canonical_hash",
    "policy_result"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "artifact_type": {
      "description": "Which plane this lifecycle event belongs to. IPLAN_CHAIN events carry the chain id in iplan_id and the chain_version_id in plan_version_id (D-0043).",
      "enum": ["IPLAN", "IPLAN_CHAIN"]
    },
    "iplan_id": {
      "description": "The plan or chain registry id this event concerns. Accepts both an IPLAN id and an IPLAN-CHAIN id (D-0043).",
      "type": "string",
      "pattern": "^IPLAN(-CHAIN)?-[0-9]{2,}$"
    },
    "plan_version_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "enum": [
        "imported",
        "validated",
        "submitted_for_review",
        "approved",
        "activated",
        "completed",
        "rejected",
        "superseded",
        "abandoned",
        "archived",
        "rolled_back"
      ]
    },
    "from_status": {
      "enum": [
        "Imported",
        "Validated",
        "Draft",
        "Review",
        "Approved",
        "Rejected",
        "Superseded",
        "Abandoned",
        "Active",
        "Completed",
        "Archived"
      ]
    },
    "to_status": {
      "enum": [
        "Imported",
        "Validated",
        "Draft",
        "Review",
        "Approved",
        "Rejected",
        "Superseded",
        "Abandoned",
        "Active",
        "Completed",
        "Archived"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "actor_type"],
      "properties": {
        "actor_id": { "type": "string", "minLength": 1 },
        "actor_type": { "enum": ["user", "service_account", "system"] }
      }
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "reason": { "type": "string", "minLength": 1 },
    "canonical_hash": {
      "description": "sha256 over iplan-canonical-json v1.0 — see docs/standards/IPLAN-CANONICALIZATION.md (D-0021).",
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "enum": ["sha256"] },
        "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "policy_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "policy_id", "checked_at", "violations"],
      "properties": {
        "result": { "enum": ["allowed", "denied", "warning"] },
        "policy_id": { "type": "string", "minLength": 1 },
        "checked_at": { "type": "string", "format": "date-time" },
        "violations": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
