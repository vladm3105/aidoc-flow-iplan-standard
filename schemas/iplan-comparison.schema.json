{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/iplan-comparison.schema.json",
  "title": "IPLAN Comparison",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "comparison_id",
    "base_ref",
    "target_ref",
    "comparison_type",
    "summary",
    "section_diffs",
    "impact",
    "approval_impact",
    "execution_impact",
    "generated_at"
  ],
  "properties": {
    "comparison_id": { "type": "string", "minLength": 1 },
    "base_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "id", "plan_version_id", "canonical_hash"],
      "properties": {
        "artifact_type": { "enum": ["IPLAN", "IPLAN_CHAIN"] },
        "id": { "type": "string", "minLength": 1 },
        "plan_version_id": { "type": ["string", "null"] },
        "canonical_hash": {
          "description": "sha256 over iplan-canonical-json v1.0 — see docs/standards/IPLAN-CANONICALIZATION.md (D-0021).",
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "enum": ["sha256"] },
            "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
          }
        }
      }
    },
    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "id", "plan_version_id", "canonical_hash"],
      "properties": {
        "artifact_type": { "enum": ["IPLAN", "IPLAN_CHAIN"] },
        "id": { "type": "string", "minLength": 1 },
        "plan_version_id": { "type": ["string", "null"] },
        "canonical_hash": {
          "description": "sha256 over iplan-canonical-json v1.0 — see docs/standards/IPLAN-CANONICALIZATION.md (D-0021).",
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "enum": ["sha256"] },
            "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
          }
        }
      }
    },
    "comparison_type": { "enum": ["version_to_version", "chain_to_chain", "document_to_document"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed", "added", "removed", "unchanged", "notes"],
      "properties": {
        "changed": { "type": "integer", "minimum": 0 },
        "added": { "type": "integer", "minimum": 0 },
        "removed": { "type": "integer", "minimum": 0 },
        "unchanged": { "type": "integer", "minimum": 0 },
        "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "section_diffs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "change_type", "summary", "before_hash", "after_hash", "breaking"],
        "properties": {
          "section": {
            "enum": [
              "intent",
              "scope",
              "lineage",
              "plan_steps",
              "executor_work",
              "commands",
              "evidence",
              "handoff",
              "navigation",
              "chain_order",
              "policy"
            ]
          },
          "change_type": { "enum": ["added", "removed", "modified", "unchanged"] },
          "summary": { "type": "string", "minLength": 1 },
          "before_hash": { "type": ["string", "null"] },
          "after_hash": { "type": ["string", "null"] },
          "breaking": { "type": "boolean" }
        }
      }
    },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "description": "Summary classification only. The actionable detail lives in the top-level approval_impact and execution_impact objects (rerun scope is execution_impact.affected_*).",
      "required": ["severity"],
      "properties": {
        "severity": { "enum": ["breaking", "review_required", "non_breaking"] }
      }
    },
    "approval_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_required", "reason", "approver_roles"],
      "properties": {
        "approval_required": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 },
        "approver_roles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "execution_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rerun_required", "affected_steps", "affected_work_orders", "affected_files"],
      "properties": {
        "rerun_required": { "type": "boolean" },
        "affected_steps": {
          "type": "array",
          "items": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
          "uniqueItems": true
        },
        "affected_work_orders": {
          "type": "array",
          "items": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
          "uniqueItems": true
        },
        "affected_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "affected_member_plans": {
          "description": "Chain member plans (iplan_id) added/removed/re-versioned between versions (PLAN-045). Empty for plan-to-plan comparisons (which use affected_steps). A subset of plan_steps-section-breaking causes — a reorder or metadata-only edit is breaking without listing a member.",
          "type": "array",
          "items": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
          "uniqueItems": true
        }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
