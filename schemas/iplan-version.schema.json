{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/iplan-version.schema.json",
  "title": "IPLAN Version",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_version_id",
    "iplan_id",
    "plan_version",
    "content_ref",
    "canonical_hash",
    "source",
    "validation",
    "approval",
    "immutability",
    "immutable",
    "supersession",
    "created_at",
    "imported_at",
    "status"
  ],
  "properties": {
    "plan_version_id": { "type": "string", "minLength": 1 },
    "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
    "plan_version": { "type": "string", "minLength": 1 },
    "content_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_ref", "uri", "media_type"],
      "properties": {
        "artifact_ref": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "media_type": { "enum": ["application/yaml", "application/json", "text/markdown"] }
      }
    },
    "canonical_hash": {
      "description": "sha256 over iplan-canonical-json v1.0 — see docs/standards/IPLAN-CANONICALIZATION.md (D-0021).",
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "enum": ["sha256"] },
        "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_system", "source_ref", "import_id"],
      "properties": {
        "source_system": { "enum": ["aidoc-flow-framework", "iplanic-api", "manual-upload", "connector"] },
        "source_ref": { "type": "string", "minLength": 1 },
        "import_id": { "type": "string", "minLength": 1 }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_report_id", "status", "exec_ready_status", "validated_at"],
      "properties": {
        "validation_report_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["not_run", "passed", "failed", "passed_with_warnings"] },
        "exec_ready_status": { "enum": ["not_ready", "ready", "ready_with_warnings"] },
        "validated_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "approved_by",
        "approved_at",
        "approved_hash",
        "policy_result",
        "exceptions"
      ],
      "properties": {
        "decision": { "enum": ["pending", "approved", "rejected", "exception_approved"] },
        "approved_by": { "type": ["string", "null"] },
        "approved_at": { "type": ["string", "null"], "format": "date-time" },
        "approved_hash": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "enum": ["sha256"] },
            "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
          }
        },
        "policy_result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["result", "policy_id", "checked_at"],
          "properties": {
            "result": { "enum": ["allowed", "denied", "warning", "not_checked"] },
            "policy_id": { "type": "string", "minLength": 1 },
            "checked_at": { "type": ["string", "null"], "format": "date-time" }
          }
        },
        "exceptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "immutability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_locked", "mutable_fields", "canonicalization"],
      "properties": {
        "content_locked": { "type": "boolean" },
        "mutable_fields": {
          "type": "array",
          "items": { "enum": ["status", "validation", "approval", "supersession"] },
          "uniqueItems": true
        },
        "canonicalization": {
          "description": "iplan-canonical-json serialization algorithm + version pin — see docs/standards/IPLAN-CANONICALIZATION.md.",
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "version"],
          "properties": {
            "algorithm": { "enum": ["iplan-canonical-json"] },
            "version": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "immutable": { "type": "boolean", "enum": [true] },
    "supersession": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supersedes_version_id", "superseded_by_version_id"],
      "properties": {
        "supersedes_version_id": { "type": ["string", "null"] },
        "superseded_by_version_id": { "type": ["string", "null"] }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "imported_at": { "type": "string", "format": "date-time" },
    "status": {
      "enum": ["Imported", "Validated", "Review", "Approved", "Superseded", "Rejected", "Abandoned"]
    }
  }
}
