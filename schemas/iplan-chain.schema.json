{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/iplan-chain.schema.json",
  "title": "IPLAN Chain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "intent",
    "plans",
    "dependencies",
    "execution_path",
    "policy",
    "initialization",
    "start_conditions",
    "chain_context",
    "evidence_requirements",
    "completion_gate",
    "inter_plan_handoffs",
    "handoff",
    "navigation",
    "semantic_rules"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "document_type", "chain_id", "title", "status", "created_at", "updated_at", "owner"],
      "properties": {
        "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(-draft)?$" },
        "document_type": { "const": "iplan-chain" },
        "chain_id": { "type": "string", "pattern": "^IPLAN-CHAIN-[0-9]{2,}$" },
        "title": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["Draft", "Review", "Approved", "Active", "Completed", "Superseded", "Abandoned"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "owner": { "type": "string", "minLength": 1 }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "outcome", "non_goals"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "non_goals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "plans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "iplan_id",
          "plan_version",
          "plan_version_id",
          "title",
          "status",
          "file_path",
          "artifact_ref",
          "version_record_ref",
          "canonical_hash",
          "exec_ready_status",
          "validation_report_id",
          "approval_event_id",
          "approved_hash",
          "approved_at"
        ],
        "properties": {
          "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
          "plan_version": { "type": "string", "minLength": 1 },
          "plan_version_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "status": { "const": "Approved" },
          "file_path": { "type": "string", "minLength": 1 },
          "artifact_ref": { "type": "string", "minLength": 1 },
          "version_record_ref": { "type": "string", "minLength": 1 },
          "canonical_hash": {
            "description": "sha256 over iplan-canonical-json v1.0 — see docs/standards/IPLAN-CANONICALIZATION.md (D-0021).",
            "type": "object",
            "additionalProperties": false,
            "required": ["algorithm", "value"],
            "properties": {
              "algorithm": { "enum": ["sha256"] },
              "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
            }
          },
          "exec_ready_status": { "enum": ["passed", "passed_with_warnings"] },
          "validation_report_id": { "type": "string", "minLength": 1 },
          "approval_event_id": { "type": "string", "minLength": 1 },
          "approved_hash": {
            "type": "object",
            "additionalProperties": false,
            "required": ["algorithm", "value"],
            "properties": {
              "algorithm": { "enum": ["sha256"] },
              "value": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
            }
          },
          "approved_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dependency_id", "from", "to", "type", "gate", "reason"],
        "properties": {
          "dependency_id": { "type": "string", "pattern": "^DEP-[0-9]{3,}$" },
          "from": {
            "type": "object",
            "additionalProperties": false,
            "required": ["iplan_id", "step_id", "work_order_id"],
            "properties": {
              "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
              "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
              "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
              "todo_id": { "type": "string", "pattern": "^TODO-[0-9]{3,}$" },
              "output_ref": { "type": "string", "minLength": 1 }
            }
          },
          "to": {
            "type": "object",
            "additionalProperties": false,
            "required": ["iplan_id", "step_id", "work_order_id"],
            "properties": {
              "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
              "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
              "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
              "todo_id": { "type": "string", "pattern": "^TODO-[0-9]{3,}$" }
            }
          },
          "type": { "enum": ["blocks", "informs", "optional"] },
          "gate": { "enum": ["completion_required", "evidence_required", "approval_required", "context_available"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "execution_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "tiers"],
      "properties": {
        "strategy": { "enum": ["tiered_dag"] },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tier",
              "label",
              "entry_gate",
              "plan_sequence",
              "parallel_safe",
              "dispatch_policy",
              "exit_gate"
            ],
            "properties": {
              "tier": { "type": "integer", "minimum": 1 },
              "label": { "type": "string", "minLength": 1 },
              "entry_gate": {
                "type": "object",
                "additionalProperties": false,
                "required": ["required_dependencies", "required_approvals"],
                "properties": {
                  "required_dependencies": {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^DEP-[0-9]{3,}$" },
                    "uniqueItems": true
                  },
                  "required_approvals": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "uniqueItems": true
                  }
                }
              },
              "plan_sequence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["sequence", "iplan_id", "dispatch_mode", "required_work_orders"],
                  "properties": {
                    "sequence": { "type": "integer", "minimum": 1 },
                    "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
                    "dispatch_mode": { "enum": ["sequential", "parallel"] },
                    "required_work_orders": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["step_id", "work_order_id"],
                        "properties": {
                          "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
                          "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" }
                        }
                      }
                    }
                  }
                }
              },
              "parallel_safe": { "type": "boolean" },
              "dispatch_policy": {
                "type": "object",
                "additionalProperties": false,
                "description": "Tier-local parallelism. Overrides the chain-level policy defaults for this tier. The per-executor cap is set chain-wide in policy.max_tasks_per_executor, not here.",
                "required": ["max_parallel_plans", "max_parallel_tasks", "require_clean_gate"],
                "properties": {
                  "max_parallel_plans": { "type": "integer", "minimum": 1 },
                  "max_parallel_tasks": { "type": "integer", "minimum": 1 },
                  "require_clean_gate": { "type": "boolean" }
                }
              },
              "exit_gate": {
                "type": "object",
                "additionalProperties": false,
                "required": ["required_events", "required_artifacts", "require_evidence_bundle"],
                "properties": {
                  "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                  "required_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                  "require_evidence_bundle": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Chain-wide concurrency caps. max_tasks_per_executor is the single source for the per-executor cap (further bounded by executor-registration.max_parallel_tasks); per-tier dispatch_policy overrides the tier-local parallelism defaults.",
      "required": [
        "max_parallel_runs",
        "max_parallel_tasks_per_tier",
        "max_tasks_per_executor",
        "require_human_gate_between_tiers",
        "conflict_strategy",
        "resource_conflict_policy"
      ],
      "properties": {
        "max_parallel_runs": { "type": "integer", "minimum": 1 },
        "max_parallel_tasks_per_tier": { "type": "integer", "minimum": 1 },
        "max_tasks_per_executor": { "type": "integer", "minimum": 1 },
        "require_human_gate_between_tiers": { "type": "boolean" },
        "conflict_strategy": { "enum": ["block_on_conflict", "cancel_lower_priority", "manual_review"] },
        "resource_conflict_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["file_lock_mode", "lock_scopes", "shared_lock_groups", "conflict_evidence_required"],
          "properties": {
            "file_lock_mode": { "enum": ["exclusive_write", "advisory", "none"] },
            "lock_scopes": {
              "type": "array",
              "items": { "enum": ["file_path", "mcp_tool", "knowledge_ref", "artifact_ref"] },
              "uniqueItems": true
            },
            "shared_lock_groups": { "type": "array", "items": { "type": "object" } },
            "conflict_evidence_required": { "type": "boolean" }
          }
        }
      }
    },
    "initialization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_status",
        "plan_version_checks",
        "graph_checks",
        "handoff_checks",
        "runtime_records"
      ],
      "properties": {
        "required_status": { "const": "Approved" },
        "plan_version_checks": {
          "type": "array",
          "items": {
            "enum": [
              "all_plan_versions_approved",
              "all_approved_hashes_match",
              "all_validation_reports_passed",
              "all_exec_ready_statuses_passed"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "graph_checks": {
          "type": "array",
          "items": {
            "enum": [
              "dependencies_resolved",
              "tiers_cover_declared_plans",
              "dependency_graph_acyclic",
              "resource_conflicts_checked"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "handoff_checks": {
          "type": "array",
          "items": {
            "enum": [
              "all_blocking_dependencies_have_handoffs",
              "handoff_sources_resolve",
              "handoff_targets_resolve"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "runtime_records": {
          "type": "object",
          "additionalProperties": false,
          "required": ["chain_execution_record_required", "plan_execution_records_required", "evidence_store_ready"],
          "properties": {
            "chain_execution_record_required": { "type": "boolean" },
            "plan_execution_records_required": { "type": "boolean" },
            "evidence_store_ready": { "type": "boolean" }
          }
        }
      }
    },
    "start_conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_tier", "required_resources", "policy_checks", "context_checks", "start_events"],
      "properties": {
        "first_tier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tier", "entry_gate_required"],
          "properties": {
            "tier": { "type": "integer", "minimum": 1 },
            "entry_gate_required": { "type": "boolean" }
          }
        },
        "required_resources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "policy_checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "context_checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "start_events": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    },
    "chain_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "knowledge_refs", "mcp_tools", "artifact_refs"],
      "properties": {
        "repository": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "default_branch", "base_ref"],
          "properties": {
            "url": { "type": "string", "minLength": 1 },
            "default_branch": { "type": "string", "minLength": 1 },
            "base_ref": { "type": "string", "minLength": 1 }
          }
        },
        "knowledge_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_type", "ref", "required"],
            "properties": {
              "ref_type": { "enum": ["spec", "decision", "knowledge_base", "code_summary", "run_log"] },
              "ref": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        },
        "mcp_tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose", "required"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        },
        "artifact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_events", "required_artifacts", "required_plan_evidence", "approvals"],
      "properties": {
        "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_artifacts": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "required_plan_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["iplan_id", "required_work_orders", "required_events"],
            "properties": {
              "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
              "required_work_orders": {
                "type": "array",
                "items": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
                "minItems": 1
              },
              "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          }
        },
        "approvals": { "type": "array", "items": { "type": "object" } }
      }
    },
    "completion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criteria",
        "required_events",
        "required_artifacts",
        "required_handoffs",
        "chain_evidence_bundle_required",
        "final_state"
      ],
      "properties": {
        "criteria": {
          "type": "array",
          "items": {
            "enum": [
              "all_required_dependencies_satisfied",
              "all_tier_exit_gates_passed",
              "all_plan_completion_gates_passed",
              "all_required_evidence_accepted"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_handoffs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^HANDOFF-[0-9]{3,}$" },
          "uniqueItems": true
        },
        "chain_evidence_bundle_required": { "type": "boolean" },
        "final_state": { "const": "Completed" }
      }
    },
    "inter_plan_handoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "handoff_id",
          "from",
          "to",
          "handoff_type",
          "required_context",
          "required_evidence",
          "acceptance_gate",
          "fallback"
        ],
        "properties": {
          "handoff_id": { "type": "string", "pattern": "^HANDOFF-[0-9]{3,}$" },
          "from": {
            "type": "object",
            "additionalProperties": false,
            "required": ["iplan_id", "step_id", "work_order_id"],
            "properties": {
              "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
              "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
              "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
              "artifact_ref": { "type": "string", "minLength": 1 }
            }
          },
          "to": {
            "type": "object",
            "additionalProperties": false,
            "required": ["iplan_id", "step_id", "work_order_id"],
            "properties": {
              "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
              "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
              "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
              "context_ref": { "type": "string", "minLength": 1 }
            }
          },
          "handoff_type": { "enum": ["context", "artifact", "approval", "evidence", "blocking"] },
          "required_context": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptance_gate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["required_events", "required_artifacts", "decision"],
            "properties": {
              "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "required_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "decision": { "enum": ["automatic", "human_approval"] }
            }
          },
          "fallback": {
            "type": "object",
            "additionalProperties": false,
            "required": ["on_missing_context", "on_rejected_evidence"],
            "properties": {
              "on_missing_context": { "type": "string", "minLength": 1 },
              "on_rejected_evidence": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_state", "resume_from", "blockers", "sessions"],
      "properties": {
        "current_state": { "type": "string", "minLength": 1 },
        "resume_from": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tier", "iplan_id", "step_id", "work_order_id"],
          "properties": {
            "tier": { "type": "integer", "minimum": 1 },
            "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
            "step_id": { "type": "string", "pattern": "^STEP-[0-9]{3,}$" },
            "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" }
          }
        },
        "blockers": { "type": "array", "items": { "type": "object" } },
        "sessions": { "type": "array", "items": { "type": "object" } }
      }
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blockers", "deferred_items", "cross_plan_obligations", "change_history"],
      "properties": {
        "blockers": { "type": "array", "items": { "type": "object" } },
        "deferred_items": { "type": "array", "items": { "type": "object" } },
        "cross_plan_obligations": { "type": "array", "items": { "type": "object" } },
        "change_history": { "type": "array", "items": { "type": "object" } }
      }
    },
    "semantic_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unique_plan_ids_required",
        "references_must_resolve",
        "acyclic_dependencies_required",
        "tiers_must_cover_declared_plans",
        "work_order_refs_must_resolve"
      ],
      "properties": {
        "unique_plan_ids_required": { "type": "boolean" },
        "references_must_resolve": { "type": "boolean" },
        "acyclic_dependencies_required": { "type": "boolean" },
        "tiers_must_cover_declared_plans": { "type": "boolean" },
        "work_order_refs_must_resolve": { "type": "boolean" }
      }
    }
  }
}
