{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iplanic.ai/schemas/task.schema.json",
  "title": "Iplanic Remote Executor Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "org_id",
    "project_id",
    "iplan_id",
    "plan_version_id",
    "run_id",
    "step_id",
    "executor_id",
    "task_type",
    "status",
    "created_at",
    "lease_expires_at",
    "context_refs",
    "required_artifacts",
    "work_order",
    "context_package",
    "reporting",
    "failure_handling"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "org_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "iplan_id": { "type": "string", "pattern": "^IPLAN-[0-9]{2,}$" },
    "protocol_plan_id": { "type": ["string", "null"], "minLength": 1 },
    "plan_version_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "step_id": { "type": "string", "minLength": 1 },
    "executor_id": { "type": "string", "pattern": "^exec:[a-z2-7]{16,}$" },
    "protocol_agent_id": { "type": ["string", "null"], "minLength": 1 },
    "task_type": {
      "enum": [
        "execute_step",
        "run_tests",
        "review_changes",
        "security_review",
        "document_update",
        "drift_analysis"
      ]
    },
    "status": { "enum": ["queued", "assigned", "running", "blocked", "succeeded", "failed", "cancelled"] },
    "created_at": { "type": "string", "format": "date-time" },
    "lease_expires_at": { "type": "string", "format": "date-time" },
    "context_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "enum": [
          "execution_log",
          "test_output",
          "changed_file_manifest",
          "review_report",
          "security_report",
          "evidence_bundle"
        ]
      },
      "uniqueItems": true
    },
    "tool_grants": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "budget_grant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_tokens": { "type": "integer", "minimum": 0 },
        "max_duration_seconds": { "type": "integer", "minimum": 0 },
        "max_cost_cents": { "type": "integer", "minimum": 0 }
      }
    },
    "work_order": {
      "type": "object",
      "additionalProperties": false,
      "required": ["work_order_id", "todos", "commands", "acceptance_criteria"],
      "properties": {
        "work_order_id": { "type": "string", "pattern": "^WORK-[0-9]{3,}$" },
        "summary": { "type": "string", "minLength": 1 },
        "todos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "todo_id",
              "description",
              "type",
              "priority",
              "allowed_actions",
              "acceptance_criteria",
              "evidence_required"
            ],
            "properties": {
              "todo_id": { "type": "string", "pattern": "^TODO-[0-9]{3,}$" },
              "description": { "type": "string", "minLength": 1 },
              "type": { "enum": ["inspect", "edit", "create", "delete", "test", "review", "document", "verify"] },
              "priority": { "enum": ["P0", "P1", "P2", "P3"] },
              "allowed_actions": {
                "type": "array",
                "items": {
                  "enum": [
                    "read",
                    "create",
                    "modify",
                    "delete",
                    "run_command",
                    "call_tool",
                    "submit_artifact",
                    "request_clarification"
                  ]
                },
                "minItems": 1,
                "uniqueItems": true
              },
              "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "evidence_required": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["event_type", "artifact_type", "description"],
                  "properties": {
                    "event_type": { "type": "string", "minLength": 1 },
                    "artifact_type": { "type": "string", "minLength": 1 },
                    "description": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["setup", "execute", "verify"],
          "properties": {
            "setup": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "execute": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
            "verify": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
          }
        },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "context_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "context_refs",
        "knowledge_refs",
        "mcp_tools",
        "tool_grants",
        "forbidden_paths",
        "secrets_policy"
      ],
      "properties": {
        "repository": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "default_branch", "base_ref"],
          "properties": {
            "url": { "type": "string", "minLength": 1 },
            "default_branch": { "type": "string", "minLength": 1 },
            "base_ref": { "type": "string", "minLength": 1 }
          }
        },
        "context_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "knowledge_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_type", "ref", "required"],
            "properties": {
              "ref_type": { "enum": ["spec", "decision", "knowledge_base", "code_summary", "run_log"] },
              "ref": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        },
        "mcp_tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose", "required"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        },
        "tool_grants": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } },
        "secrets_policy": { "enum": ["no_secrets", "scoped_runtime_only", "managed_by_iplanic"] }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_events",
        "required_artifacts",
        "artifact_manifest_required",
        "final_summary_required"
      ],
      "properties": {
        "required_events": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "artifact_manifest_required": { "type": "boolean" },
        "final_summary_required": { "type": "boolean" },
        "progress_interval_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "failure_handling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["on_blocker", "on_ambiguity", "on_test_failure", "on_policy_denial", "on_partial_completion"],
      "properties": {
        "on_blocker": { "type": "string", "minLength": 1 },
        "on_ambiguity": { "type": "string", "minLength": 1 },
        "on_test_failure": { "type": "string", "minLength": 1 },
        "on_policy_denial": { "type": "string", "minLength": 1 },
        "on_partial_completion": { "type": "string", "minLength": 1 }
      }
    }
  }
}
